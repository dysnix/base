set dotenv-path := "devnet-env"
set working-directory := '../..'

_ha := "-f etc/docker/docker-compose.yml -f etc/docker/docker-compose.ha.yml"
_base := "-f etc/docker/docker-compose.yml"
_env := "--env-file etc/docker/devnet-env"

# Show devnet commands
default:
    @just --justfile {{source_file()}} --list

# Stops devnet, deletes data, and starts fresh (3-node HA conductor cluster)
up: down _build-setup-image (_build-rust-images "devnet" "dev")
    docker compose {{ _env }} {{ _ha }} up -d --no-build --scale contender=0

# Stops devnet, deletes data, and starts fresh with a single sequencer (no conductor)
up-single: down _build-setup-image (_build-rust-images "devnet" "dev")
    docker compose {{ _env }} {{ _base }} up -d --no-build --scale contender=0

# Stops devnet, deletes data, and starts fresh with profiling (Pyroscope + optimized builds)
profiling: down _build-setup-image (_build-rust-images "devnet" "profiling")
    docker compose {{ _env }} {{ _ha }} --profile profiling up -d --no-build --scale contender=0

# Stops devnet and deletes all data
down:
    -docker compose {{ _env }} {{ _ha }} --profile profiling down
    -docker run --rm -v "$(pwd)/.devnet:/devnet" alpine sh -c 'rm -rf /devnet/*'

# Shows devnet block numbers and sync status
status:
    ./etc/scripts/devnet/status.sh

# Shows devnet container status
ps *services:
    docker compose {{ _env }} {{ _ha }} ps {{ services }}

# Shows funded test accounts with live balances and nonces
accounts:
    ./etc/scripts/devnet/accounts.sh

# Sends test transactions to L1 and L2
smoke:
    ./etc/scripts/devnet/smoke.sh

# Runs full devnet checks (status + smoke tests)
checks: status smoke

# Starts the contender load generator
load:
    docker compose {{ _base }} up -d --no-deps contender

# Stops the contender load generator
load-down:
    docker compose {{ _base }} down contender

# Stream FB's from the builder via websocket
flashblocks:
    @command -v flashblocks-websocket-client >/dev/null 2>&1 || go install github.com/danyalprout/flashblocks-websocket-client@latest
    flashblocks-websocket-client ws://localhost:${L2_BUILDER_FLASHBLOCKS_PORT}

# Stream logs from devnet containers (optionally specify container names)
logs *containers:
    docker compose {{ _env }} {{ _ha }} logs -f {{ containers }}

# Stream logs from the sequencer's execution (EL) and consensus (CL) layers
sequencer-logs:
    docker compose {{ _env }} {{ _ha }} logs -f base-builder base-builder-cl

# Follow the active raft leader's CL logs, switching automatically on failover
follow-leader:
    ./etc/scripts/devnet/follow-leader.sh

# Stop the active sequencer and transfer raft leadership (optionally to node 0, 1, or 2)
transfer-leader to='':
    ./etc/scripts/devnet/transfer-leader.sh {{ to }}

# TUI dashboard: HA conductor cluster monitor (requires devnet running)
conductor:
    cargo run --quiet -p basectl -- conductor

# Vibenet: public devnet fronted by Cloudflare. Single sequencer + nginx
# gateway + faucet + contract deployer. Requires etc/vibenet/vibenet-env
# (copy from vibenet-env.example and fill in secrets before running).
#
# On production hosts that have had a Cloudflare Origin CA certificate
# installed at /etc/vibenet/tls/origin.{crt,key}, the `public` overlay is
# auto-included to expose the :443 TLS listener that Cloudflare connects
# to. Laptops without that cert get the local-dev stack only (loopback
# ports 18080/18081/18082/18083).
vibe: vibe-down _build-setup-image (_build-rust-images "devnet" "dev")
    #!/usr/bin/env bash
    set -euo pipefail
    if [ ! -f etc/vibenet/vibenet-env ]; then
      echo "ERROR: etc/vibenet/vibenet-env missing. Copy from etc/vibenet/vibenet-env.example." >&2
      exit 1
    fi
    export VIBENET_BRANCH="$(git rev-parse --abbrev-ref HEAD)"
    export VIBENET_COMMIT="$(git rev-parse --short HEAD)"
    public_overlay=
    if [ -f /etc/vibenet/tls/origin.crt ]; then
      public_overlay="-f etc/vibenet/docker-compose.public.yml"
      echo "[vibe] public overlay enabled (/etc/vibenet/tls/origin.crt found)"
    fi
    docker compose \
      --env-file etc/docker/devnet-env \
      --env-file etc/vibenet/vibenet-env \
      -f etc/docker/docker-compose.yml \
      -f etc/vibenet/docker-compose.vibenet.yml \
      $public_overlay \
      up -d --build --scale contender=0

# Stops vibenet and deletes all data. `-v` wipes the named volumes so state
# that lives outside `.devnet/` (vibescan sqlite, rendered UI config, the
# shared contracts.json, admin htpasswd) doesn't survive a chain reset -
# otherwise e.g. vibescan's indexer would keep pointing at a pre-reset
# cursor and silently drop new blocks below it.
vibe-down:
    #!/usr/bin/env bash
    set -euo pipefail
    public_overlay=
    if [ -f /etc/vibenet/tls/origin.crt ]; then
      public_overlay="-f etc/vibenet/docker-compose.public.yml"
    fi
    docker compose \
      --env-file etc/docker/devnet-env \
      --env-file etc/vibenet/vibenet-env \
      -f etc/docker/docker-compose.yml \
      -f etc/vibenet/docker-compose.vibenet.yml \
      $public_overlay \
      down --remove-orphans -v || true
    docker run --rm -v "$(pwd)/.devnet:/devnet" alpine sh -c 'rm -rf /devnet/*' || true

# In-place rebuild of just the faucet, UI config, and nginx gateway. Leaves
# the chain (L1/L2 + proxyd + vibescan) running with no state reset, so
# balances, contracts, block history, and the explorer index all survive.
# Use this when iterating on:
#   - crates/vibenet/faucet/          (Rust: triggers an image rebuild)
#   - apps/vibenet-ui/public/*        (HTML/JS/CSS: bind-mounted; a browser
#                                      refresh is actually enough, this
#                                      recipe just ensures nginx is fresh)
#   - etc/vibenet/config/vibenet.yaml (rerun by vibenet-config-renderer)
#   - etc/vibenet/nginx/*.template    (picked up when nginx restarts)
#
# For anything that touches the chain (base-client/builder/setup/proxyd)
# or the vibescan index you still want a full `just vibe`, which wipes
# state and starts fresh. For vibescan-only tweaks we can add a
# `vibe-explorer` sibling if iteration pain becomes a thing.
vibe-faucet:
    #!/usr/bin/env bash
    set -euo pipefail
    if [ ! -f etc/vibenet/vibenet-env ]; then
      echo "ERROR: etc/vibenet/vibenet-env missing. Copy from etc/vibenet/vibenet-env.example." >&2
      exit 1
    fi
    export VIBENET_BRANCH="$(git rev-parse --abbrev-ref HEAD)"
    export VIBENET_COMMIT="$(git rev-parse --short HEAD)"
    public_overlay=
    if [ -f /etc/vibenet/tls/origin.crt ]; then
      public_overlay="-f etc/vibenet/docker-compose.public.yml"
    fi
    # Rebuild the faucet image and recreate only its container. --no-deps
    # keeps base-client and friends untouched (they're already healthy).
    # --force-recreate swaps the old container out even if the image hash
    # is the same, so config changes (env vars, volumes) take effect.
    docker compose \
      --env-file etc/docker/devnet-env \
      --env-file etc/vibenet/vibenet-env \
      -f etc/docker/docker-compose.yml \
      -f etc/vibenet/docker-compose.vibenet.yml \
      $public_overlay \
      up -d --no-deps --build --force-recreate vibenet-faucet
    # Re-run the yq config renderer (one-shot that writes a fresh
    # /srv/config/config.json) and recreate nginx so it re-runs envsubst
    # over the conf template. The static UI bind mount needs no action -
    # nginx serves whatever is on disk now.
    docker compose \
      --env-file etc/docker/devnet-env \
      --env-file etc/vibenet/vibenet-env \
      -f etc/docker/docker-compose.yml \
      -f etc/vibenet/docker-compose.vibenet.yml \
      $public_overlay \
      up -d --no-deps --force-recreate vibenet-config-renderer nginx-gateway

